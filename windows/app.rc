#include <windows.h>

// Tray / app icon (matches IDI_APPICON used in App.cpp).
#define IDI_APPICON 101
IDI_APPICON ICON "app.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    0,1,0,0
 PRODUCTVERSION 0,1,0,0
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName",      "vbar.io"
      VALUE "FileDescription",  "ScreenFlip — mirror a monitor into a usable flipped workspace"
      VALUE "FileVersion",      "0.1.0.0"
      VALUE "InternalName",     "ScreenFlip"
      VALUE "OriginalFilename", "ScreenFlip.exe"
      VALUE "ProductName",      "ScreenFlip"
      VALUE "ProductVersion",   "0.1.0.0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x409, 1200
  END
END

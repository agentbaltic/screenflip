desktop.ini

# The macOS distribution build is intentionally committed (the README links to
# macos/build/ScreenFlip.zip), so re-include just those artifacts despite the
# build/ and *.app rules above — without un-ignoring .DS_Store etc.
!macos/build/
!macos/build/ScreenFlip.zip
!macos/build/ScreenFlip.app/
!macos/build/ScreenFlip.app/**

build/
*.app

# macOS
.DS_Store

# Swift / Xcode
.build/
DerivedData/
*.xcuserstate
*.swiftpm

# Windows / MSVC build intermediates
*.obj
*.exe
*.pdb
*.ilk
*.exp
*.lib
*.res
*.cso

# Build output
build/
*.app

# macOS
.DS_Store

# Swift / Xcode
.build/
DerivedData/
*.xcuserstate
*.swiftpm

# Windows / MSVC build intermediates
*.obj
*.exe
*.pdb
*.ilk
*.exp
*.lib
*.res
*.cso
*.idb
windows/build/
windows/driver/**/x64/
windows/driver/**/Debug/
windows/driver/**/Release/
Thumbs.db
desktop.ini

# The macOS distribution DMG is intentionally committed (the README links to
# macos/build/ScreenFlip-<version>.dmg), so re-include just the built DMG despite
# the build/ rule above — without un-ignoring .DS_Store, the loose .app, etc.
!macos/build/
macos/build/*
!macos/build/*.dmg
